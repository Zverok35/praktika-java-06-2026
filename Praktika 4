public class ArrayTask {
    public static void main(String[] args) {
        // 1. Создать массив из 5 целых чисел
        int[] numbers = {10, 25, 7, 42, 18};

        // 2 Вывести все элементы массива
        System.out.println("Элементы массива:");
        for (int i = 0; i < numbers.length; i++) {
            System.out.print(numbers[i] + " ");
        }
        System.out.println(); // Переход на новую строку

        // 3. Найти и вывести сумму всех элементов
        int sum = 0;
        for (int i = 0; i < numbers.length; i++) {
            sum += numbers[i];
        }
        System.out.println("Сумма элементов: " + sum);

        // 4. Найти и вывести максимальное значение
        int max = numbers; // Предполагаем, что первый элемент — максимальный
        for (int i = 1; i < numbers.length; i++) {
            if (numbers[i] > max) {
                max = numbers[i];
            }
        }
        System.out.println("Максимальное значение: " + max);

        // 5. Дополнительно: Проверить, содержится ли в массиве число 42
        boolean found = false;
        for (int i = 0; i < numbers.length; i++) {
            if (numbers[i] == 42) {
                found = true;
                break; // Можно прервать цикл, как только нашли нужное число
            }
        }
        if (found) {
            System.out.println("Число 42 содержится в массиве.");
        } else {
            System.out.println("Число 42 не содержится в массиве.");
        }
    }
}
